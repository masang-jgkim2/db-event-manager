PORT=4000
JWT_SECRET=event-manager-secret-key-change-in-production
JWT_EXPIRES_IN=24h
# MSSQL: 구버전/비암호화 TDS만 쓰는 서버에서 연결 실패 시 false (기본: 암호화 사용)
# MSSQL_ENCRYPT=false
# 데이터 폴더 (미설정 시 process.cwd()/data). 백엔드 한 곳만 실행 시 한 세트만 유지
# DATA_DIR=data
# 활동 로그: 1 / true / on / yes 만 기록(미설정·0 = 비기록). 개발에서 쓰려면 아래 주석 해제
# ACTIVITY_LOG_ENABLED=1
# 활동 로그 JSON 배치 저장(기본 2000ms 디바운스, 200건마다 즉시 저장). 비정상 종료 시 마지막 flush 이후 유실 가능
# ACTIVITY_LOG_FLUSH_MS=2000
# ACTIVITY_LOG_FLUSH_EVERY=200
# ACTIVITY_LOG_MAX_ROWS=10000
