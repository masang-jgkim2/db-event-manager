PORT=4000
# 앱 메타 저장소: json(기본)=backend/data/*.json | mysql=정규화 메타 테이블(+기동 시 JSON→DB 옵션)
# DATA_STORE=mysql
# DATA_MYSQL_URL=mysql://root:비밀번호@127.0.0.1:3306/dqpm_meta
# 또는 분리: DATA_MYSQL_HOST DATA_MYSQL_PORT DATA_MYSQL_USER DATA_MYSQL_PASSWORD DATA_MYSQL_DATABASE
# 빈 DB일 때 data/*.json 자동 적재 끄기: DATA_MYSQL_NO_JSON_IMPORT=1
# dbConnections.json·MySQL db_connection 비밀번호 선택 암호화(AES-256-GCM, 접두 enc:v1:). 16자 미만·미설정이면 평문 유지
# 설정 시 디스크에 평문 strPassword 가 있으면 서버 기동 1회 JSON을 enc:v1 로 덮어씀(Jest 제외). 저장 API·npm run encrypt-db-connections-json 동일
# DB_CONNECTION_PASSWORD_SECRET=랜덤-긴-문자열-16자이상-권장
# LAN에서 PC 이름 등으로 프론트 접속 시 SSE(EventSource) CORS 허용 — 내부망 전용, 운영 공개망에서는 켜지 말 것
# DQPM_RELAX_CORS=true
JWT_SECRET=event-manager-secret-key-change-in-production
JWT_EXPIRES_IN=24h
# MSSQL: 구버전/비암호화 TDS만 쓰는 서버에서 연결 실패 시 false (기본: 암호화 사용)
# MSSQL_ENCRYPT=false
# 데이터 폴더 (미설정 시 process.cwd()/data). 백엔드 한 곳만 실행 시 한 세트만 유지
# DATA_DIR=data
# 활동 로그: 1 / true / on / yes 만 기록(미설정·0 = 비기록). 개발에서 쓰려면 아래 주석 해제
# ACTIVITY_LOG_ENABLED=1
# 활동 로그 JSON 배치 저장(기본 2000ms 디바운스, 200건마다 즉시 저장). 비정상 종료 시 마지막 flush 이후 유실 가능
# ACTIVITY_LOG_FLUSH_MS=2000
# ACTIVITY_LOG_FLUSH_EVERY=200
# ACTIVITY_LOG_MAX_ROWS=10000
