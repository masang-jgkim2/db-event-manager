PORT=4000
JWT_SECRET=event-manager-secret-key-change-in-production
JWT_EXPIRES_IN=24h
# MSSQL: 구버전/비암호화 TDS만 쓰는 서버에서 연결 실패 시 false (기본: 암호화 사용)
# MSSQL_ENCRYPT=false
# 데이터 폴더 (미설정 시 process.cwd()/data). 백엔드 한 곳만 실행 시 한 세트만 유지
# DATA_DIR=data

# 영속 백엔드: json(기본) | rdb — rdb 시 시스템 DB(MSSQL, DB_SYSTEM_*) + 마이그레이션
STORE_BACKEND=json
# rdb + seed_test.json: 기본 무시. 시드 메모리 적용 후 DB에 밀어 넣으려면 1
# SEED_TEST_WITH_RDB=1
# 롤백: STORE_BACKEND=json + npm run backup:data 로 떠둔 data 백업 복원

# 시스템 DB (STORE_BACKEND=rdb, 마이그레이션·db_connections 저장)
# DB_SYSTEM_HOST=127.0.0.1
# DB_SYSTEM_PORT=1433
# DB_SYSTEM_DATABASE=db_manager
# DB_SYSTEM_USER=dba
# DB_SYSTEM_PASSWORD=
